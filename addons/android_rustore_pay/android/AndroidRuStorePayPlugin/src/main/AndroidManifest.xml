<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <!--
            Registers this library as a Godot 4 Android Plugin v2.
            The value must match: com.shinobi.rustorepay.<ClassName>
            The key must match:   org.godotengine.plugin.v2.<PluginName>
            where PluginName matches getPluginName() in the Kotlin class.
        -->
        <meta-data
            android:name="org.godotengine.plugin.v2.AndroidRuStorePay"
            android:value="com.shinobi.rustorepay.AndroidRuStorePayPlugin" />
    </application>
</manifest>

; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Naruto Clicker"
run/main_scene="uid://vp5q6agyccmk"
config/features=PackedStringArray("4.5", "GL Compatibility")
boot_splash/image="uid://d2xxh4ek0b7ag"
config/icon="uid://b2er20jnl6rl0"

[autoload]

BuildConfig="*res://scripts/game/BuildConfig.gd"
YandexBridge="*res://autoload/YandexBridge.gd"
SaveManager="*res://autoload/SaveManager.gd"
LocalizationManager="*res://scripts/ui/LocalizationManager.gd"
AudioManager="*res://autoload/AudioManager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1600
window/stretch/mode="canvas_items"
window/handheld/orientation=1
window/size/viewport_height.web=1280

[editor_plugins]

enabled=PackedStringArray("res://addons/localization_sync/plugin.cfg")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
